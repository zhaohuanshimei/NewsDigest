# =============================================================================
# News Digest V2 - Environment Variables Template
# =============================================================================
# 本文件是全项目统一的环境变量模板。复制为 .env 并填入实际值。
# 注意:不要将真实密钥提交到版本控制系统。
# =============================================================================

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL 连接字符串
# 开发环境默认值: postgresql+psycopg://news:news@localhost:5432/news_digest
# 生产环境应使用不同的数据库凭证和连接参数
DATABASE_URL=postgresql+psycopg://news:news@localhost:5432/news_digest

# =============================================================================
# API 服务配置
# =============================================================================

# API 服务端口 (默认: 8001)
# API_PORT=8001

# API 前缀 (默认: /api/v1)
# 修改此项需同步更新 services/api/app/core/config.py
# API_PREFIX=/api/v1

# =============================================================================
# 翻译服务配置
# =============================================================================

# DeepL API 密钥 (可选,至少配置一个翻译服务)
DEEPL_API_KEY=

# Google Translate API 密钥 (可选,至少配置一个翻译服务)
GOOGLE_TRANSLATE_API_KEY=

# =============================================================================
# 前端配置
# =============================================================================

# API Base URL - 前端调用后端 API 的地址
# 开发环境默认值: http://127.0.0.1:8001/api/v1
NEWS_DIGEST_API_BASE_URL=http://127.0.0.1:8001/api/v1

# 站点 URL - 用于生成 sitemap、RSS 等
# 开发环境: http://localhost:4321
# 生产环境: https://your-domain.com
SITE_URL=http://localhost:4321

# =============================================================================
# 前端 Mock 状态覆盖 (仅开发/测试环境使用)
# =============================================================================
# 这些变量用于前端开发时模拟不同的数据状态,生产环境不应设置。
# 有效值:
#   PUBLIC_DIGEST_STATE: "success" | "empty" | "error"
#   PUBLIC_ARCHIVE_STATE: "success" | "empty" | "error"
#   PUBLIC_CLUSTER_STATE: "success" | "not-found" | "error"
# PUBLIC_DIGEST_STATE=
# PUBLIC_ARCHIVE_STATE=
# PUBLIC_CLUSTER_STATE=

# =============================================================================
# 发布与部署配置
# =============================================================================

# 前端构建完成后的 webhook URL (可选)
# 用于触发前端重新部署或缓存刷新
FRONTEND_BUILD_WEBHOOK_URL=

# =============================================================================
# 运行时配置
# =============================================================================

# 日志级别 (默认: INFO)
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 时区 (默认: Asia/Shanghai)
TZ=Asia/Shanghai

# =============================================================================
# 环境差异说明
# =============================================================================
#
# 开发环境 (Development):
#   - DATABASE_URL 指向本地 PostgreSQL
#   - NEWS_DIGEST_API_BASE_URL 指向本地 API 服务
#   - SITE_URL 指向本地前端开发服务器
#   - 可以设置 PUBLIC_*_STATE 变量进行前端开发调试
#   - LOG_LEVEL 可设为 DEBUG
#
# 测试环境 (Testing):
#   - DATABASE_URL 指向测试数据库(独立的数据库实例)
#   - NEWS_DIGEST_API_BASE_URL 指向测试 API 服务
#   - SITE_URL 指向测试前端地址
#   - 不应设置 PUBLIC_*_STATE 变量
#   - LOG_LEVEL 建议 INFO 或 WARNING
#
# 预发环境 (Staging):
#   - DATABASE_URL 指向预发数据库(与生产隔离的独立实例)
#   - NEWS_DIGEST_API_BASE_URL 指向预发 API 服务
#   - SITE_URL 指向预发前端地址
#   - 不应设置 PUBLIC_*_STATE 变量
#   - LOG_LEVEL 建议 INFO
#   - 翻译 API 密钥应使用预发环境的凭证
#
# 生产环境 (Production):
#   - DATABASE_URL 使用强密码和生产数据库连接参数
#   - NEWS_DIGEST_API_BASE_URL 使用生产域名和 HTTPS
#   - SITE_URL 使用生产域名和 HTTPS
#   - 绝不应设置 PUBLIC_*_STATE 变量
#   - LOG_LEVEL 建议 INFO 或 WARNING
#   - 翻译 API 密钥必须使用生产环境的凭证
#   - FRONTEND_BUILD_WEBHOOK_URL 应配置为生产部署触发 URL
#   - 所有敏感信息通过环境变量或密钥管理服务注入
#
# =============================================================================
# 安全提醒
# =============================================================================
#
# 1. 绝不要将真实的 API 密钥、数据库密码提交到版本控制系统
# 2. 生产环境的敏感配置应通过以下方式之一管理:
#    - 环境变量 (推荐用于容器化部署)
#    - 密钥管理服务 (AWS Secrets Manager, GCP Secret Manager, etc.)
#    - 加密配置文件 (需配合解密工具)
# 3. .env 文件已被 .gitignore 排除,不会被提交
# 4. 定期轮换 API 密钥和数据库凭证
# 5. 不同环境使用不同的凭证,避免交叉污染
#
# =============================================================================
