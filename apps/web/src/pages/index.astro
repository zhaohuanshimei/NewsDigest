---
import DigestEntryList from "../components/digest/DigestEntryList.astro";
import DigestHeader from "../components/digest/DigestHeader.astro";
import EmptyState from "../components/states/EmptyState.astro";
import ErrorState from "../components/states/ErrorState.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../lib/config/site";
import { loadHomepageDigest } from "../lib/content/getLatestDigest";
import BaseLayout from "../layouts/BaseLayout.astro";

const homepageDigest = await loadHomepageDigest();

const siteUrl = Astro.site?.origin ?? "https://newsdigest.app";
const jsonLd = homepageDigest.kind === "success" ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE_TITLE,
  "description": SITE_DESCRIPTION,
  "url": siteUrl,
  "datePublished": homepageDigest.digest.published_at,
  "inLanguage": "en"
} : null;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} canonicalPath="/">
  <main class="page-shell">
    <section class="page-intro" aria-label="Site introduction" data-lang="zh">
      <p class="page-eyebrow">News Digest</p>
      <div class="d-zh">
        <h1 class="page-title">为一天的核心新闻，留一份安静的头版。</h1>
        <p class="page-description">
          一次读完当日精选摘要，按重要性排序的事件聚类，简明扼要。
        </p>
      </div>
      <div class="d-en">
        <h1 class="page-title">A quiet front page for the day&apos;s essential stories.</h1>
        <p class="page-description">
          Read the latest digest in one pass, with ranked clusters and concise summaries.
        </p>
      </div>
    </section>

    {
      homepageDigest.kind === "success" ? (
        <section class="digest-surface" aria-label="Latest digest">
          <DigestHeader
            date={homepageDigest.digest.date}
            publishedAt={homepageDigest.digest.published_at.replace("T", " ").replace("Z", " UTC")}
          />
          <DigestEntryList entries={homepageDigest.digest.entries} />
        </section>
      ) : homepageDigest.kind === "empty" ? (
        <EmptyState />
      ) : (
        <ErrorState message={homepageDigest.message} />
      )
    }
  </main>

  {jsonLd && (
    <div set:html={`<script type="application/ld+json">${JSON.stringify(jsonLd)}</script>`} />
  )}
</BaseLayout>
