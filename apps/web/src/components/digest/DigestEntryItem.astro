---
import type { DigestEntryResource } from "../../../../../packages/shared-types/src/index.ts";

interface Props {
  entry: DigestEntryResource;
}

const { entry } = Astro.props;

function stripHtml(text: string): string {
  return text
    .replace(/<[^>]*>/g, "")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'")
    .trim();
}

const headlineZh = entry.headline_translated || entry.headline;
const summaryZh = stripHtml(entry.summary_translated || entry.summary);
const headlineEn = entry.headline;
const summaryEn = stripHtml(entry.summary);

const entryId = `entry-${entry.rank}`;
const sources = entry.sources || [];
const imageUrl = entry.image_url || "";
const videoUrl = entry.video_url || "";
const sourceText = sources.length > 0
  ? `${entry.source_count} sources · ${sources.slice(0, 3).join(", ")}${sources.length > 3 ? " +" + (sources.length - 3) : ""}`
  : `${entry.source_count} sources`;
---

<article class="digest-entry" id={entryId} data-lang="zh" data-category={entry.category || "general"}>
  {imageUrl && (
    <div class="digest-entry-media">
      <img src={imageUrl} alt={headlineEn} loading="lazy" class="digest-entry-image" />
    </div>
  )}
  {videoUrl && !imageUrl && (
    <div class="digest-entry-media">
      <a href={videoUrl} target="_blank" rel="noopener" class="digest-entry-video-link">
        <span class="digest-entry-video-badge">▶ Video</span>
      </a>
    </div>
  )}

  <div class="digest-entry-bar">
    <p class="digest-entry-rank">{entry.rank.toString().padStart(2, "0")}</p>
    <div class="digest-entry-lang-tools">
      <button class="lang-btn is-active" data-lang="zh" data-entry={entryId}>中</button>
      <button class="lang-btn" data-lang="en" data-entry={entryId}>EN</button>
      <button class="lang-btn" data-lang="both" data-entry={entryId}>中+EN</button>
    </div>
  </div>

  <div class="d-zh">
    <h3 class="digest-entry-headline">
      <a class="digest-entry-link" href={`/clusters/${entry.cluster_id}/`}>{headlineZh}</a>
    </h3>
    <p class="digest-entry-summary">{summaryZh}</p>
  </div>

  <div class="d-en">
    <p class="d-en-label">原文</p>
    <h3 class="digest-entry-headline">{headlineEn}</h3>
    <p class="digest-entry-summary">{summaryEn}</p>
  </div>

  <p class="digest-entry-meta">{sourceText}</p>
</article>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".lang-btn");
    if (!btn) return;

    const entryEl = document.getElementById(
      (btn as HTMLElement).getAttribute("data-entry") || ""
    );
    if (!entryEl) return;

    const lang = (btn as HTMLElement).getAttribute("data-lang") || "zh";
    entryEl.setAttribute("data-lang", lang);

    entryEl.querySelectorAll(".lang-btn").forEach((b) => {
      b.classList.toggle(
        "is-active",
        b.getAttribute("data-lang") === lang
      );
    });
  });
</script>

<style>
  .digest-entry {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    border-bottom: 1px solid var(--surface-border);
  }

  .digest-entry:last-child {
    border-bottom: 0;
  }

  .digest-entry-media {
    width: 100%;
    margin-bottom: 0.25rem;
    border-radius: 2px;
    overflow: hidden;
  }

  .digest-entry-image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 18rem;
    object-fit: cover;
  }

  .digest-entry-video-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 10rem;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid var(--surface-border);
    border-radius: 2px;
    text-decoration: none;
  }

  .digest-entry-video-badge {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--headline-text);
  }

  .digest-entry-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .digest-entry-lang-tools {
    display: flex;
    gap: 0.15rem;
  }

  .lang-btn {
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--surface-border);
    background: transparent;
    color: var(--muted-text);
    cursor: pointer;
    border-radius: 2px;
    font-family: inherit;
    transition: all 0.15s ease;
  }

  .lang-btn:hover {
    color: var(--headline-text);
    border-color: var(--headline-text);
  }

  .lang-btn.is-active {
    background: var(--headline-text);
    color: var(--page-background);
    border-color: var(--headline-text);
  }

  .digest-entry-rank {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-text);
  }

  .digest-entry-headline {
    max-width: 28ch;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .digest-entry-summary {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--muted-text);
  }

  .digest-entry-meta {
    font-size: 0.8rem;
    color: var(--muted-text);
  }

  .digest-entry-link {
    color: inherit;
    text-decoration: none;
  }

  .digest-entry-link:hover,
  .digest-entry-link:focus-visible {
    text-decoration: underline;
  }

  .d-en {
    display: none;
  }

  .d-en-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 0.4rem;
  }

  .digest-entry[data-lang="en"] .d-zh {
    display: none;
  }

  .digest-entry[data-lang="en"] .d-en {
    display: grid;
    gap: 0.85rem;
  }

  .digest-entry[data-lang="en"] .d-en-label {
    display: none;
  }

  .digest-entry[data-lang="both"] .d-en {
    display: grid;
    gap: 0.85rem;
    padding: 0.75rem;
    margin-top: 0.5rem;
    background: rgba(0, 0, 0, 0.03);
    border-left: 2px solid var(--surface-border);
  }

  @media (min-width: 48rem) {
    .digest-entry {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  /* ---- Image layout: left / right ---- */

  body[data-img-layout="left"] .digest-entry-media,
  body[data-img-layout="right"] .digest-entry-media {
    width: 38%;
    margin-bottom: 0;
  }

  body[data-img-layout="left"] .digest-entry-media {
    float: left;
    margin-right: 1.75rem;
  }

  body[data-img-layout="right"] .digest-entry-media {
    float: right;
    margin-left: 1.75rem;
  }

  @media (max-width: 48rem) {
    body[data-img-layout="left"] .digest-entry-media,
    body[data-img-layout="right"] .digest-entry-media {
      float: none;
      width: 100%;
      margin: 0 0 0.25rem;
    }
  }
</style>
