---
interface Props {
  category: string;
  headline: string;
  summary: string;
  headlineTranslated?: string;
  summaryTranslated?: string;
}

const { category, headline, summary, headlineTranslated, summaryTranslated } = Astro.props;

const displayHeadline = headlineTranslated || headline;
const displaySummary = summaryTranslated || summary;
---

<header class="cluster-header">
  <p class="page-eyebrow">{category}</p>
  <h1 class="cluster-title">{displayHeadline}</h1>
  <p class="cluster-summary">{displaySummary}</p>
</header>
