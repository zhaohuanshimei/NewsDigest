---
interface Props {
  category: string;
  headline: string;
  summary: string;
  headlineTranslated?: string;
  summaryTranslated?: string;
}

const { category, headline, summary, headlineTranslated, summaryTranslated } = Astro.props;

function stripHtml(text: string): string {
  return text
    .replace(/<[^>]*>/g, "")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'")
    .trim();
}

const headlineZh = headlineTranslated || headline;
const summaryZh = stripHtml(summaryTranslated || summary);
const headlineEn = headline;
const summaryEn = stripHtml(summary);
---

<header class="cluster-header" id="cluster-header" data-lang="zh">
  <div class="cluster-header-bar">
    <p class="page-eyebrow">{category}</p>
    <div class="cluster-lang-tools">
      <button class="lang-btn is-active" data-lang="zh" data-target="cluster-header">中</button>
      <button class="lang-btn" data-lang="en" data-target="cluster-header">EN</button>
      <button class="lang-btn" data-lang="both" data-target="cluster-header">中+EN</button>
    </div>
  </div>

  <div class="d-zh">
    <h1 class="cluster-title">{headlineZh}</h1>
    <p class="cluster-summary">{summaryZh}</p>
  </div>

  <div class="d-en">
    <p class="d-en-label">原文</p>
    <h1 class="cluster-title">{headlineEn}</h1>
    <p class="cluster-summary">{summaryEn}</p>
  </div>
</header>

<style>
  .cluster-header {
    display: grid;
    gap: 0.9rem;
    padding: 0 1.5rem 2rem;
    border-bottom: 1px solid var(--surface-border);
  }

  .cluster-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cluster-lang-tools {
    display: flex;
    gap: 0.15rem;
  }

  .lang-btn {
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--surface-border);
    background: transparent;
    color: var(--muted-text);
    cursor: pointer;
    border-radius: 2px;
    font-family: inherit;
    transition: all 0.15s ease;
  }

  .lang-btn:hover {
    color: var(--headline-text);
    border-color: var(--headline-text);
  }

  .lang-btn.is-active {
    background: var(--headline-text);
    color: var(--page-background);
    border-color: var(--headline-text);
  }

  .cluster-title {
    max-width: 26ch;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .cluster-summary {
    max-width: 42rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--muted-text);
  }

  .d-en {
    display: none;
  }

  .d-en-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-text);
    margin-bottom: 0.4rem;
  }

  .cluster-header[data-lang="en"] .d-zh {
    display: none;
  }

  .cluster-header[data-lang="en"] .d-en {
    display: grid;
    gap: 0.9rem;
  }

  .cluster-header[data-lang="en"] .d-en-label {
    display: none;
  }

  .cluster-header[data-lang="both"] .d-en {
    display: grid;
    gap: 0.9rem;
    padding: 0.75rem;
    margin-top: 0.5rem;
    background: rgba(0, 0, 0, 0.03);
    border-left: 2px solid var(--surface-border);
  }

  @media (min-width: 48rem) {
    .cluster-header {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".lang-btn");
    if (!btn) return;

    const target = document.getElementById(
      (btn as HTMLElement).getAttribute("data-target") || ""
    );
    if (!target) return;

    const lang = (btn as HTMLElement).getAttribute("data-lang") || "zh";
    target.setAttribute("data-lang", lang);

    target.querySelectorAll(".lang-btn").forEach((b) => {
      b.classList.toggle(
        "is-active",
        b.getAttribute("data-lang") === lang
      );
    });
  });
</script>
