# =============================================================================
# News Digest V2 — Astro 静态站点 Dockerfile
# =============================================================================
# 多阶段构建：
#   1. builder: Node 安装依赖 + 构建 Astro 静态文件
#   2. runner:  nginx 提供静态文件
#
# 构建上下文必须是仓库根目录（因为 apps/web 依赖 packages/shared-types）
#   docker build -f infra/Dockerfile.web -t news-digest-v2-web .
#
# 构建时环境变量：
#   NEWS_DIGEST_API_BASE_URL — API 地址（SSG 构建时拉数据）
#   PUBLIC_DIGEST_STATE      — mock 状态覆盖（仅开发用）
#   SITE_URL                 — 站点 URL（影响 sitemap/RSS）
# =============================================================================

FROM node:22-alpine AS builder

WORKDIR /app

# 先复制 package.json 和 lock 文件，利用 Docker 缓存
COPY packages/shared-types/package.json packages/shared-types/package-lock.json ./packages/shared-types/
COPY apps/web/package.json apps/web/package-lock.json ./apps/web/

# 安装 shared-types 依赖
RUN cd packages/shared-types && npm ci

# 安装 web 依赖
RUN cd apps/web && npm ci

# 复制源码
COPY packages/shared-types/ ./packages/shared-types/
COPY apps/web/ ./apps/web/

# 构建 Astro 静态站点
ARG NEWS_DIGEST_API_BASE_URL=""
ARG PUBLIC_DIGEST_STATE=""
ARG SITE_URL="https://news.maczhao.com"

ENV NEWS_DIGEST_API_BASE_URL=${NEWS_DIGEST_API_BASE_URL}
ENV PUBLIC_DIGEST_STATE=${PUBLIC_DIGEST_STATE}
ENV SITE_URL=${SITE_URL}

RUN cd apps/web && npm run build

# ──────────────────────────────────────────────────────────────────────────
# Runner: nginx 提供静态文件
# ──────────────────────────────────────────────────────────────────────────

FROM nginx:alpine

# 复制 Astro 构建产物
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# nginx 配置：SPA 回退 + 静态文件缓存 + gzip
RUN cat > /etc/nginx/conf.d/default.conf <<'EOF'
server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1024;

    # 静态文件缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # HTML 不缓存（确保更新及时）
    location ~* \.html$ {
        add_header Cache-Control "no-cache";
    }

    # Astro SSG: 页面都是 .html 文件，URI 不带 .html 后缀
    location / {
        try_files $uri $uri/ $uri.html /404.html;
    }

    # feed.xml 和 sitemap-index.xml 等特殊文件
    location = /feed.xml {
        try_files $uri =404;
        add_header Content-Type "application/rss+xml";
    }
}
EOF

EXPOSE 80
