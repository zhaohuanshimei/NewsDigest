# =============================================================================
# News Digest - Production Environment Variables
# =============================================================================
# 复制为 .env.production 并填入实际生产值。
# 敏感信息应通过密钥管理服务注入，不要提交到版本控制。
# =============================================================================

# 生产数据库连接字符串（使用强密码）
DATABASE_URL=postgresql+psycopg2://news:your-strong-password@db:5432/news_digest

# API 服务端口
API_PORT=8001

# 日志级别
LOG_LEVEL=INFO

# 翻译 API 密钥（使用生产环境的凭证）
DEEPL_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# 前端使用的 API 地址（生产域名，必须 HTTPS）
NEWS_DIGEST_API_BASE_URL=https://api.newsdigest.app/api/v1

# 站点 URL（生产域名，用于 sitemap/RSS）
SITE_URL=https://newsdigest.app

# 前端构建触发 webhook（可选，用于后端生产流水线完成后触发前端重建）
FRONTEND_BUILD_WEBHOOK_URL=

# 时区
TZ=Asia/Shanghai
