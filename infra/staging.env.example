# =============================================================================
# News Digest - Staging Environment Variables
# =============================================================================
# 复制为 .env.staging 并填入实际值。
# =============================================================================

# 预发数据库连接字符串
DATABASE_URL=postgresql+psycopg2://news:news_staging@localhost:5433/news_digest

# API 服务端口
API_PORT=8001

# 日志级别
LOG_LEVEL=INFO

# 翻译 API 密钥 (使用预发环境的凭证)
DEEPL_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# 前端使用的 API 地址 (预发环境 API 域名)
NEWS_DIGEST_API_BASE_URL=https://api-staging.newsdigest.app/api/v1

# 站点 URL (预发环境前端域名)
SITE_URL=https://staging.newsdigest.app
