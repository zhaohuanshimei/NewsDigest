---
/**
 * Tag — small label for categories, topics, and metadata.
 *
 * Variants:
 *   default — neutral border, subtle background
 *   accent  — accent background tint
 *   muted   — low-contrast, less prominent
 *
 * Can render as <a> by passing `href`.
 */

interface Props {
  variant?: "default" | "accent" | "muted";
  size?: "sm" | "md";
  href?: string;
  class?: string;
  [key: string]: any;
}

const {
  variant = "default",
  size = "md",
  href,
  class: className,
  ...attrs
} = Astro.props;

const Tag = href ? "a" : "span";
---

<Tag
  class:list={["tag", `tag--${variant}`, `tag--${size}`, className]}
  href={href}
  {...attrs}
>
  <slot />
</Tag>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-button, 2px);
    font-family: var(--font-sans, sans-serif);
    font-weight: var(--font-medium, 500);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider, 0.06em);
    line-height: 1;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    border: 1px solid transparent;
  }

  /* ── Sizes ──────────────────────────────────────────────── */

  .tag--sm {
    padding: var(--space-1, 4px) var(--space-2, 8px);
    font-size: var(--text-xs, 12px);
  }

  .tag--md {
    padding: var(--space-2, 8px) var(--space-3, 12px);
    font-size: var(--text-xs, 12px);
  }

  /* ── Variants ───────────────────────────────────────────── */

  .tag--default {
    background: var(--color-bg-muted, #fafafa);
    color: var(--color-text-secondary, #404040);
    border-color: var(--color-border-light, #ebebeb);
  }

  .tag--accent {
    background: var(--color-bg-active, #e8f0f8);
    color: var(--color-link, #2e6ea6);
    border-color: transparent;
  }

  .tag--muted {
    background: transparent;
    color: var(--color-text-muted, #5c5c5c);
    border-color: var(--color-border-light, #ebebeb);
  }

  /* ── Link tags ──────────────────────────────────────────── */

  a.tag {
    cursor: pointer;
    transition:
      background var(--transition-fast, 150ms ease),
      border-color var(--transition-fast, 150ms ease);
  }

  a.tag:hover {
    background: var(--color-bg-hover, #f5f5f5);
    border-color: var(--color-border, #d4d4d4);
  }

  a.tag--accent:hover {
    background: var(--color-bg-active, #e8f0f8);
    border-color: var(--color-border-focus, #2e6ea6);
  }
</style>
