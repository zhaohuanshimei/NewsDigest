---
/**
 * SourceBadge — inline badge marking an article's source or origin.
 *
 * Props:
 *   name — source name (required, displayed text)
 *   href — optional link to the source
 *   size — sm | md (default md)
 *
 * Renders as <a> when href is provided, otherwise <span>.
 */

interface Props {
  name: string;
  href?: string;
  size?: "sm" | "md";
  class?: string;
  [key: string]: any;
}

const {
  name,
  href,
  size = "md",
  class: className,
  ...attrs
} = Astro.props;

const Tag = href ? "a" : "span";
---

<Tag
  class:list={["source-badge", `source-badge--${size}`, className]}
  href={href}
  {...attrs}
>
  {name}
  <slot />
</Tag>

<style>
  .source-badge {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-button, 2px);
    font-family: var(--font-sans, sans-serif);
    font-weight: var(--font-medium, 500);
    line-height: 1;
    white-space: nowrap;
    color: var(--color-text-secondary, #404040);
    background: var(--color-bg-muted, #fafafa);
    border: 1px solid var(--color-border-light, #ebebeb);
    text-decoration: none;
    transition:
      background var(--transition-fast, 150ms ease),
      border-color var(--transition-fast, 150ms ease);
  }

  /* ── Sizes ──────────────────────────────────────────────── */

  .source-badge--sm {
    padding: var(--space-1, 4px) var(--space-2, 8px);
    font-size: 11px;
    letter-spacing: var(--tracking-wide, 0.02em);
  }

  .source-badge--md {
    padding: var(--space-1, 4px) var(--space-3, 12px);
    font-size: var(--text-sm, 13px);
    letter-spacing: var(--tracking-wide, 0.02em);
  }

  /* ── Link variant ───────────────────────────────────────── */

  a.source-badge:hover {
    background: var(--color-bg-hover, #f5f5f5);
    border-color: var(--color-border, #d4d4d4);
    color: var(--color-text-primary, #000);
  }
</style>
