---
/**
 * Card — bordered surface container.
 *
 * Props:
 *   padding — "sm" | "md" | "lg" | "none"  (default "md")
 *   element — wrapper HTML tag              (default "div")
 *   href    — if set, renders as <a>
 *
 * Content goes in the default <slot />.
 */

interface Props {
  padding?: "none" | "sm" | "md" | "lg";
  element?: "div" | "article" | "section" | "li";
  href?: string;
  class?: string;
  [key: string]: any;
}

const {
  padding = "md",
  element = "div",
  href,
  class: className,
  ...attrs
} = Astro.props;

const Tag = href ? "a" : element;
---

<Tag
  class:list={["card", `card--padding-${padding}`, className]}
  href={href}
  {...attrs}
>
  <slot />
</Tag>

<style>
  .card {
    display: block;
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border, #d4d4d4);
    border-radius: var(--radius-card, 4px);
  }

  /* ── Padding variants ───────────────────────────────────── */

  .card--padding-none {
    padding: 0;
  }

  .card--padding-sm {
    padding: var(--space-3, 12px);
  }

  .card--padding-md {
    padding: var(--space-6, 24px);
  }

  .card--padding-lg {
    padding: var(--space-8, 32px);
  }

  /* ── Link card ──────────────────────────────────────────── */

  a.card {
    color: inherit;
    text-decoration: none;
    transition: border-color var(--transition-fast, 150ms ease);
  }

  a.card:hover {
    border-color: var(--color-text-primary, #000);
  }
</style>
